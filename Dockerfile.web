FROM nginx:alpine

COPY web/landing/index.html /usr/share/nginx/html/index.html
COPY web/landing/cameras.html /usr/share/nginx/html/cameras.html
COPY web/landing/privacy.html /usr/share/nginx/html/privacy.html
COPY web/landing/terms.html /usr/share/nginx/html/terms.html
COPY web/landing/legal.html /usr/share/nginx/html/legal.html
COPY web/landing/team.html /usr/share/nginx/html/team.html
COPY web/landing/docs.html /usr/share/nginx/html/docs.html
COPY web/landing/404.html /usr/share/nginx/html/404.html
COPY web/landing/blog/ /usr/share/nginx/html/blog/
COPY web/landing/robots.txt /usr/share/nginx/html/robots.txt
COPY web/landing/sitemap.xml /usr/share/nginx/html/sitemap.xml
COPY web/dashboard/ /usr/share/nginx/html/dashboard/
COPY nginx.conf /etc/nginx/nginx.conf

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
