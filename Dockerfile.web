FROM nginx:alpine

COPY web/landing/index.html /usr/share/nginx/html/index.html
COPY web/landing/cameras.html /usr/share/nginx/html/cameras.html
COPY web/landing/blog/ /usr/share/nginx/html/blog/
COPY web/landing/robots.txt /usr/share/nginx/html/robots.txt
COPY web/landing/sitemap.xml /usr/share/nginx/html/sitemap.xml
COPY nginx.conf /etc/nginx/nginx.conf

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
